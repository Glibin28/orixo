@media(prefers-reduced-motion:reduce){
  *{animation:none!important;transition:none!important}
  #cursor,#cursor-ring{display:none}
  body{cursor:auto}
}
.facility-section{
  padding:120px 8%;
}

.facility-grid{
  margin-top:60px;
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:24px;
}

.machine-card{
  background:#0e1118;
  border-radius:24px;
  padding:25px;
  text-align:center;
  border:1px solid rgba(255,255,255,.08);
  position:relative;
  overflow:hidden;
  transition:.4s;
}

.machine-card:hover{
  transform:translateY(-8px);
}

.machine-card h3{
  color:#fff;
  margin-top:20px;
  margin-bottom:12px;
}

.machine-status{
  display:inline-block;
  padding:8px 18px;
  border-radius:30px;
  font-size:.8rem;
  font-weight:700;
  letter-spacing:1px;
}

/* =====================
   PRINTER MODEL
===================== */

.printer-model{
  width:140px;
  height:120px;
  margin:auto;
  position:relative;
}

.frame{
  position:absolute;
  inset:0;
  border:3px solid currentColor;
}

.head{
  width:28px;
  height:14px;
  background:currentColor;
  position:absolute;
  top:18px;
  animation:printHead 2s linear infinite;
}

.static{
  left:55px;
  animation:none;
}

.object{
  position:absolute;
  bottom:12px;
  left:50%;
  transform:translateX(-50%);
  width:40px;
  background:currentColor;
  animation:growPrint 4s ease-in-out infinite;
}

@keyframes printHead{
  0%{left:10px;}
  50%{left:100px;}
  100%{left:10px;}
}

@keyframes growPrint{
  0%{height:8px;}
  50%{height:45px;}
  100%{height:8px;}
}

/* =====================
   DESIGNER
===================== */

.designer-model{
  width:140px;
  height:120px;
  margin:auto;
}

.screen{
  width:120px;
  height:80px;
  border:3px solid currentColor;
  margin:auto;
  display:flex;
  align-items:center;
  justify-content:center;
}

.cube{
  width:35px;
  height:35px;
  border:2px solid currentColor;
  transform-style:preserve-3d;
  animation:spinCube 4s linear infinite;
}

.static-cube{
  animation:none;
}

@keyframes spinCube{
  from{
    transform:rotate(0deg);
  }
  to{
    transform:rotate(360deg);
  }
}

/* =====================
   SCANNER
===================== */

.scanner-model{
  width:140px;
  height:120px;
  margin:auto;
  position:relative;
}

.scan-object{
  width:50px;
  height:50px;
  border:3px solid currentColor;
  border-radius:8px;
  position:absolute;
  left:45px;
  top:30px;
}

.scan-line{
  position:absolute;
  top:0;
  left:20px;
  width:100px;
  height:2px;
  background:currentColor;
}

/* =====================
   STATES
===================== */

.busy{
  color:#ff4545;
  box-shadow:0 0 25px rgba(255,69,69,.15);
}

.busy .machine-status{
  background:#ff4545;
  color:white;
}

.busy::before{
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(
    90deg,
    transparent,
    rgba(255,69,69,.15),
    transparent
  );
  animation:scan 2s linear infinite;
}

.free{
  color:#23d85d;
  box-shadow:0 0 25px rgba(35,216,93,.1);
}

.free .machine-status{
  background:#23d85d;
  color:#041009;
}

.scanner{
  color:#ff9f1c;
  box-shadow:0 0 25px rgba(255,159,28,.15);
}

.scanner .machine-status{
  background:#ff9f1c;
  color:#111;
}

@keyframes scan{
  from{
    transform:translateX(-100%);
  }
  to{
    transform:translateX(100%);
  }
}

/* =====================
   FOOTER
===================== */

.facility-footer{
  margin-top:50px;
  display:flex;
  justify-content:center;
  gap:30px;
  color:#cfd7df;
  font-weight:600;
  flex-wrap:wrap;
}

.active-dot,
.free-dot,
.scanner-dot{
  display:inline-block;
  width:10px;
  height:10px;
  border-radius:50%;
  margin-right:8px;
}

.active-dot{background:#ff4545;}
.free-dot{background:#23d85d;}
.scanner-dot{background:#ff9f1c;}m:rotate(360deg);}
}

/* =====================
   FORM
===================== */

/* ===== ORIXO UPLOAD TERMINAL ===== */

#contactForm{
  position:relative;
  display:grid;
  gap:18px;
  padding:40px;
  background:
    linear-gradient(180deg,#0e1118,#08090c);
  border:1px solid rgba(232,98,42,.15);
  overflow:hidden;
}

/* animated blueprint grid */
#contactForm::before{
  content:"";
  position:absolute;
  inset:0;
  background:
    linear-gradient(rgba(75,174,214,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(75,174,214,.04) 1px, transparent 1px);
  background-size:35px 35px;
  animation:gridMove 25s linear infinite;
  pointer-events:none;
}

@keyframes gridMove{
  from{transform:translateY(0)}
  to{transform:translateY(35px)}
}

/* glowing corner cuts */

#contactForm::after{
  content:"PROJECT TERMINAL";
  position:absolute;
  top:12px;
  right:20px;
  font-size:.65rem;
  letter-spacing:.3em;
  color:rgba(75,174,214,.6);
  font-family:var(--font-mono);
}

/* inputs */

#contactForm input,
#contactForm select,
#contactForm textarea{
  position:relative;
  z-index:2;
  background:rgba(8,9,12,.85);
  border:none;
  border-left:4px solid var(--orange);
  color:var(--white);
  padding:18px 22px;
  font-family:var(--font-mono);
  transition:.35s;
}

#contactForm input:hover,
#contactForm select:hover,
#contactForm textarea:hover{
  transform:translateX(8px);
}

#contactForm input:focus,
#contactForm select:focus,
#contactForm textarea:focus{
  outline:none;
  transform:translateX(12px);
  box-shadow:
  -12px 0 0 rgba(232,98,42,.15),
  0 0 35px rgba(232,98,42,.15);
}

#contactForm textarea{
  min-height:180px;
}

/* placeholders */

#contactForm input::placeholder,
#contactForm textarea::placeholder{
  color:#6f7788;
  letter-spacing:.08em;
}

/* FILE INPUT */

#contactForm input[type=file]{
  border:2px dashed rgba(75,174,214,.3);
  background:
  linear-gradient(
    135deg,
    rgba(75,174,214,.03),
    rgba(232,98,42,.03)
  );
  padding:28px;
}

#contactForm input[type=file]::-webkit-file-upload-button{
  background:transparent;
  border:1px solid var(--cyan);
  color:var(--cyan);
  padding:12px 20px;
  margin-right:20px;
  font-family:var(--font-mono);
  transition:.3s;
}

#contactForm input[type=file]::-webkit-file-upload-button:hover{
  background:var(--cyan);
  color:#000;
}

/* SUBMIT BUTTON */

#contactForm button{
  position:relative;
  width:260px;
  height:60px;
  background:none;
  border:none;
  color:var(--white);
  font-family:var(--font-mono);
  letter-spacing:.2em;
  overflow:hidden;
  align-self:flex-start;
}

/* rotating frame */

#contactForm button::before{
  content:"";
  position:absolute;
  inset:0;
  border:1px solid var(--orange);
  animation:rotateFrame 6s linear infinite;
}

@keyframes rotateFrame{
  from{
    transform:rotate(0deg);
  }
  to{
    transform:rotate(360deg);
  }
}

#contactForm button::after{
  content:"SEND PROJECT";
  position:absolute;
  inset:4px;
  background:var(--void);
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:2;
}

#contactForm button:hover::after{
  background:var(--orange);
  color:var(--void);
}

/* terminal lights */

#contactForm .terminal-light{
  position:absolute;
  width:10px;
  height:10px;
  border-radius:50%;
  top:18px;
}

#contactForm .terminal-light:nth-child(1){
  left:20px;
  background:#ff4545;
}

#contactForm .terminal-light:nth-child(2){
  left:40px;
  background:#ffd93d;
}

#contactForm .terminal-light:nth-child(3){
  left:60px;
  background:#23d85d;
}
/* ===== COMPACT PREMIUM FORM ===== */

#contactForm{
  position:relative;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:16px;
  padding:32px;
  align-items:start;
}

#contactForm input,
#contactForm select{
  width:100%;
  min-height:52px;
  padding:14px 18px;
}

#contactForm textarea{
  grid-column:1 / span 2;
  min-height:140px;
  padding:16px 18px;
}

#contactForm input[type="file"]{
  grid-column:1 / span 2;
  padding:18px;
}

#contactForm button{
  grid-column:1 / span 2;
  justify-self:center;
  width:220px;
  height:52px;
  margin-top:6px;
}

#contactForm::after{
  top:10px;
  right:16px;
  font-size:.55rem;
}

@media(max-width:768px){

  #contactForm{
    grid-template-columns:1fr;
    padding:24px 18px;
    gap:14px;
  }

  #contactForm textarea,
  #contactForm input[type="file"],
  #contactForm button{
    grid-column:auto;
  }

  #contactForm button{
    width:100%;
  }
}
#successMsg{
  display:none;
  grid-column:1 / -1;
  text-align:center;
  color:var(--cyan);
  font-family:var(--font-mono);
  font-size:.8rem;
  padding:12px;
  border:1px solid rgba(0,212,255,.2);
  background:rgba(0,212,255,.05);
}
</style>
