<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ── CURSOR ──
const cur=document.getElementById('cursor'),ring=document.getElementById('cursor-ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px'});
(function anim(){rx+=(mx-rx)*.15;ry+=(my-ry)*.15;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(anim)})();

// ── NAV ──
const nav=document.getElementById('nav');
window.addEventListener('scroll',()=>nav.classList.toggle('stuck',scrollY>60),{passive:true});

// ── HAMBURGER ──
const ham=document.getElementById('hambtn'),mob=document.getElementById('mobileMenu');
let mobOpen=false;
ham.addEventListener('click',()=>{
  mobOpen=!mobOpen;
  mob.classList.toggle('open',mobOpen);
  const sp=ham.querySelectorAll('span');
  if(mobOpen){sp[0].style.transform='rotate(45deg) translate(4px,4px)';sp[1].style.opacity='0';sp[2].style.transform='rotate(-45deg) translate(4px,-4px)'}
  else{sp.forEach(s=>{s.style.transform='';s.style.opacity=''})}
});
function closeMob(){mobOpen=false;mob.classList.remove('open');ham.querySelectorAll('span').forEach(s=>{s.style.transform='';s.style.opacity=''})}

// ── PARTICLE CANVAS (filament threads) ──
const canvas=document.getElementById('particleCanvas'),ctx=canvas.getContext('2d');
let W,H,pts=[];
function resize(){W=canvas.width=canvas.offsetWidth;H=canvas.height=canvas.offsetHeight}
resize();
window.addEventListener('resize',()=>{resize();init()});

function init(){
  pts=[];
  const N=Math.floor(W*H/14000);
  for(let i=0;i<N;i++)pts.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*.3,vy:(Math.random()-.5)*.3,r:Math.random()*1.5+.5,alpha:Math.random()*.6+.2});
}
init();

let pmx=W/2,pmy=H/2;
document.addEventListener('mousemove',e=>{pmx=e.clientX;pmy=e.clientY});

function draw(){
  ctx.clearRect(0,0,W,H);
  pts.forEach(p=>{
    p.x+=p.vx+(pmx/W-.5)*.08;
    p.y+=p.vy+(pmy/H-.5)*.08;
    if(p.x<0)p.x=W;if(p.x>W)p.x=0;
    if(p.y<0)p.y=H;if(p.y>H)p.y=0;
    ctx.beginPath();
    ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
    ctx.fillStyle=`rgba(232,98,42,${p.alpha})`;
    ctx.fill();
  });
  // connections
  for(let i=0;i<pts.length;i++){
    for(let j=i+1;j<pts.length;j++){
      const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<100){
        ctx.beginPath();
        ctx.moveTo(pts[i].x,pts[i].y);
        ctx.lineTo(pts[j].x,pts[j].y);
        ctx.strokeStyle=`rgba(232,98,42,${.12*(1-d/100)})`;
        ctx.lineWidth=.5;
        ctx.stroke();
      }
    }
  }
  requestAnimationFrame(draw);
}
draw();

// ── REVEAL ON SCROLL ──
const revEls=document.querySelectorAll('.reveal');
const revObs=new IntersectionObserver(entries=>{
  entries.forEach((e,i)=>{
    if(e.isIntersecting){setTimeout(()=>e.target.classList.add('in'),i*60);revObs.unobserve(e.target)}
  });
},{threshold:.12});
revEls.forEach(el=>revObs.observe(el));

// ── PROCESS LINE FILL ──
const procObs=new IntersectionObserver(entries=>{
  if(entries[0].isIntersecting){
    document.getElementById('lineFill').style.width='100%';
    document.querySelectorAll('.step').forEach((s,i)=>setTimeout(()=>s.classList.add('active'),i*300+200));
    procObs.disconnect();
  }
},{threshold:.3});
const pt=document.getElementById('processTrack');
if(pt)procObs.observe(pt);

// ── COUNTER ANIMATION ──
function counter(el,target,decimals=0,dur=1600){
  let start=null;
  function step(ts){
    if(!start)start=ts;
    const prog=Math.min((ts-start)/dur,1);
    const ease=1-Math.pow(1-prog,3);
    el.textContent=decimals?(ease*target).toFixed(decimals):Math.floor(ease*target);
    if(prog<1)requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}
const statObs=new IntersectionObserver(entries=>{
  if(entries[0].isIntersecting){
    counter(document.getElementById('s1'),500);
    counter(document.getElementById('s2'),48);
    counter(document.getElementById('s3'),1,1);
    statObs.disconnect();
  }
},{threshold:.5});
const ss=document.getElementById('stats');
if(ss)statObs.observe(ss);

// ── PORTFOLIO FILTER ──
document.querySelectorAll('.pf-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.pf-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    const f=btn.dataset.f;
    document.querySelectorAll('.port-item').forEach(item=>{
      item.classList.toggle('hidden',f!=='all'&&item.dataset.cat!==f);
    });
  });
});

// ── DROP ZONE ──
const dz=document.getElementById('dz'),fi=document.getElementById('fi');
dz.addEventListener('click',()=>fi.click());
fi.addEventListener('change',()=>{if(fi.files[0])document.getElementById('fn2').textContent='// '+fi.files[0].name});
['dragenter','dragover'].forEach(ev=>dz.addEventListener(ev,e=>{e.preventDefault();dz.classList.add('dz-over')}));
['dragleave','drop'].forEach(ev=>dz.addEventListener(ev,e=>{e.preventDefault();dz.classList.remove('dz-over');if(ev==='drop'&&e.dataTransfer.files[0])document.getElementById('fn2').textContent='// '+e.dataTransfer.files[0].name}));
</script>
</body>
