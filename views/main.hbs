<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ORIXO — 3D Printing Studio</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --void:#08090C;
  --steel:#0E1118;
  --plate:#161B26;
  --orange:#E8622A;
  --orange-dim:#A8401A;
  --cyan:#00D4FF;
  --white:#F0EDE8;
  --muted:#5A6070;
  --line:rgba(240,237,232,0.06);
  --font-main:'Space Grotesk',sans-serif;
  --font-mono:'DM Mono',monospace;
}
html{scroll-behavior:smooth}
body{background:var(--void);color:var(--white);font-family:var(--font-main);overflow-x:hidden;cursor:none}

/* CUSTOM CURSOR */
#cursor{position:fixed;width:10px;height:10px;border-radius:50%;background:var(--orange);pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:transform .1s;mix-blend-mode:difference}
#cursor-ring{position:fixed;width:36px;height:36px;border-radius:50%;border:1px solid rgba(232,98,42,.4);pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:all .18s ease}
body:has(a:hover) #cursor-ring{width:52px;height:52px;border-color:var(--orange)}
body:has(button:hover) #cursor-ring{width:52px;height:52px;border-color:var(--cyan)}

/* ─── NAV ─── */
#nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1.5rem 2.5rem;display:flex;align-items:center;justify-content:space-between;transition:background .4s,padding .4s}
#nav.stuck{background:rgba(8,9,12,.92);backdrop-filter:blur(16px);padding:1rem 2.5rem;border-bottom:1px solid var(--line)}
.nav-logo{display:flex;align-items:center;gap:.75rem;text-decoration:none}
.nav-logo-mark{width:26px;height:26px;position:relative;transform-style:preserve-3d;transform:rotateX(-30deg) rotateY(40deg)}
.nav-logo-mark .f{position:absolute;inset:0;border-radius:3px}
.nav-logo-mark .ft{background:#4BAED6;transform:rotateX(90deg) translateZ(14px)}
.nav-logo-mark .fl{background:var(--orange);transform:rotateY(-90deg) translateZ(14px)}
.nav-logo-mark .ff{background:#bf5020;transform:translateZ(14px)}
.nav-wordmark{font-family:var(--font-main);font-weight:700;font-size:1.1rem;letter-spacing:.12em;color:var(--white)}
.nav-links{display:flex;align-items:center;gap:2rem;list-style:none}
.nav-links a{font-family:var(--font-mono);font-size:.75rem;letter-spacing:.1em;color:var(--muted);text-decoration:none;transition:color .2s}
.nav-links a:hover{color:var(--white)}
.nav-cta{font-family:var(--font-mono);font-size:.75rem;letter-spacing:.1em;border:1px solid var(--orange);color:var(--orange);background:transparent;padding:.5rem 1.25rem;text-decoration:none;transition:all .2s;cursor:none}
.nav-cta:hover{background:var(--orange);color:var(--void)}
.nav-hamburger{display:none;flex-direction:column;gap:5px;cursor:none;background:none;border:none;padding:.25rem}
.nav-hamburger span{display:block;width:24px;height:1px;background:var(--white);transition:all .3s}

/* MOBILE MENU */
#mobileMenu{position:fixed;inset:0;background:var(--void);z-index:90;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2rem;transform:translateX(100%);transition:transform .4s cubic-bezier(.77,0,.175,1)}
#mobileMenu.open{transform:translateX(0)}
#mobileMenu a{font-family:var(--font-main);font-size:2.5rem;font-weight:700;color:var(--white);text-decoration:none;letter-spacing:-.02em;transition:color .2s}
#mobileMenu a:hover{color:var(--orange)}

/* ─── HERO ─── */
.hero{height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 2.5rem 5rem;position:relative;overflow:hidden}
#particleCanvas{position:absolute;inset:0;width:100%;height:100%}
.hero-scan{position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--orange),transparent);animation:scanDown 6s linear infinite;opacity:.5}
@keyframes scanDown{0%{top:-2px}100%{top:100%}}
.hero-tag{font-family:var(--font-mono);font-size:.72rem;letter-spacing:.2em;color:var(--cyan);text-transform:uppercase;margin-bottom:1.5rem;position:relative;z-index:2}
.hero-title{font-size:clamp(3.5rem,9vw,8rem);font-weight:700;line-height:.92;letter-spacing:-.04em;position:relative;z-index:2;color:var(--white)}
.hero-title em{display:block;font-style:normal;color:var(--orange);-webkit-text-stroke:0;text-stroke:0}
.hero-title .hollow{-webkit-text-stroke:1px rgba(240,237,232,.25);color:transparent}
.hero-bottom{display:flex;align-items:flex-end;justify-content:space-between;margin-top:2.5rem;position:relative;z-index:2}
.hero-desc{font-family:var(--font-mono);font-size:.82rem;color:var(--muted);line-height:1.8;max-width:340px}
.hero-actions{display:flex;gap:1rem;align-items:center}
.btn-primary-ox{background:var(--orange);color:var(--void);font-family:var(--font-mono);font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;padding:.85rem 2rem;border:none;text-decoration:none;display:inline-block;transition:all .25s;cursor:none;clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,0 100%)}
.btn-primary-ox:hover{background:var(--white);color:var(--void)}
.btn-outline-ox{border:1px solid var(--muted);color:var(--muted);font-family:var(--font-mono);font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;padding:.85rem 2rem;text-decoration:none;display:inline-block;transition:all .25s;cursor:none;background:transparent}
.btn-outline-ox:hover{border-color:var(--white);color:var(--white)}
.hero-scroll{display:flex;flex-direction:column;align-items:center;gap:.75rem;position:absolute;right:2.5rem;bottom:5rem;z-index:2}
.hero-scroll span{font-family:var(--font-mono);font-size:.65rem;letter-spacing:.2em;color:var(--muted);writing-mode:vertical-rl}
.scroll-track{width:1px;height:60px;background:var(--line);position:relative;overflow:hidden}
.scroll-track::after{content:'';position:absolute;top:-100%;left:0;width:1px;height:100%;background:var(--orange);animation:scrollDot 2.5s ease-in-out infinite}
@keyframes scrollDot{0%{top:-100%}100%{top:100%}}

/* LAYER LINES DIVIDER */
.layer-div{width:100%;height:24px;position:relative;overflow:hidden;margin:0}
.layer-div::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(240,237,232,.04) 2px,rgba(240,237,232,.04) 4px)}

/* ─── SERVICES ─── */
.section-ox{padding:7rem 2.5rem}
.section-tag{font-family:var(--font-mono);font-size:.68rem;letter-spacing:.25em;color:var(--orange);text-transform:uppercase;margin-bottom:1rem;display:block}
.section-title-ox{font-size:clamp(2.2rem,5vw,4rem);font-weight:700;letter-spacing:-.03em;line-height:1.05;color:var(--white)}
.section-title-ox span{color:var(--orange)}

.services-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line);border:1px solid var(--line);margin-top:4rem}
.svc-card{background:var(--void);padding:2.5rem 2rem;position:relative;overflow:hidden;transition:background .3s;cursor:none}
.svc-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--orange);transform:scaleX(0);transform-origin:left;transition:transform .4s}
.svc-card:hover{background:var(--steel)}
.svc-card:hover::before{transform:scaleX(1)}
.svc-num{font-family:var(--font-mono);font-size:.65rem;letter-spacing:.2em;color:var(--muted);margin-bottom:2.5rem}
.svc-icon-wrap{width:48px;height:48px;border:1px solid var(--line);display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;transition:border-color .3s}
.svc-card:hover .svc-icon-wrap{border-color:var(--orange)}
.svc-icon-wrap svg{width:22px;height:22px;stroke:var(--muted);transition:stroke .3s}
.svc-card:hover .svc-icon-wrap svg{stroke:var(--orange)}
.svc-name{font-family:var(--font-main);font-size:1.05rem;font-weight:600;color:var(--white);margin-bottom:.75rem}
.svc-desc{font-family:var(--font-mono);font-size:.75rem;color:var(--muted);line-height:1.75}
.svc-arrow{position:absolute;bottom:2rem;right:2rem;font-family:var(--font-mono);font-size:.75rem;color:var(--muted);opacity:0;transform:translateX(-8px);transition:all .3s}
.svc-card:hover .svc-arrow{opacity:1;transform:translateX(0);color:var(--orange)}

/* ─── PROCESS ─── */
.process-section{background:var(--steel);padding:7rem 2.5rem}
.process-track{position:relative;margin-top:5rem}
.process-line{position:absolute;top:28px;left:0;right:0;height:1px;background:var(--line)}
.process-line-fill{position:absolute;top:28px;left:0;height:1px;background:var(--orange);width:0;transition:width 1.2s ease}
.steps{display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;position:relative;z-index:1}
.step{cursor:none}
.step-dot{width:56px;height:56px;border:1px solid var(--line);background:var(--steel);display:flex;align-items:center;justify-content:center;margin-bottom:2rem;position:relative;transition:all .4s}
.step-dot::after{content:'';position:absolute;inset:-4px;border:1px solid transparent;transition:border-color .4s}
.step.active .step-dot{border-color:var(--orange);background:rgba(232,98,42,.08)}
.step.active .step-dot::after{border-color:rgba(232,98,42,.3)}
.step-dot span{font-family:var(--font-mono);font-size:.72rem;color:var(--muted);letter-spacing:.1em;transition:color .4s}
.step.active .step-dot span{color:var(--orange)}
.step-name{font-family:var(--font-main);font-weight:600;font-size:.95rem;color:var(--white);margin-bottom:.5rem}
.step-info{font-family:var(--font-mono);font-size:.73rem;color:var(--muted);line-height:1.7}

/* ─── MATERIALS ─── */
.materials-section{padding:7rem 2.5rem;background:var(--void)}
.mat-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:1px;background:var(--line);border:1px solid var(--line);margin-top:4rem}
.mat-card{background:var(--void);padding:2rem 1.25rem;display:flex;flex-direction:column;align-items:center;gap:1rem;cursor:none;transition:background .3s;position:relative;overflow:hidden}
.mat-card:hover{background:var(--steel)}
.mat-swatch{width:40px;height:4px;border-radius:0;transition:transform .3s}
.mat-card:hover .mat-swatch{transform:scaleX(1.5)}
.mat-label{font-family:var(--font-mono);font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:var(--white)}
.mat-sub{font-family:var(--font-mono);font-size:.62rem;color:var(--muted);text-align:center;line-height:1.6}
.mat-temp{font-family:var(--font-mono);font-size:.65rem;color:var(--cyan);margin-top:.25rem}

/* ─── PORTFOLIO ─── */
.portfolio-section{padding:7rem 2.5rem;background:var(--steel)}
.port-filters{display:flex;gap:.75rem;margin-top:3rem;flex-wrap:wrap}
.pf-btn{font-family:var(--font-mono);font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;border:1px solid var(--line);background:transparent;color:var(--muted);padding:.45rem 1.1rem;cursor:none;transition:all .2s}
.pf-btn.active,.pf-btn:hover{border-color:var(--orange);color:var(--orange)}
.port-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);margin-top:2rem}
.port-item{background:var(--void);overflow:hidden;position:relative;aspect-ratio:1;cursor:none;transition:background .3s}
.port-item:first-child{
  grid-column:span 1;
  aspect-ratio:1;
}
.port-item:hover .port-overlay{opacity:1}
.port-item.hidden{display:none}
.port-visual{width:100%;height:100%;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.port-shape{
  width:100%;
  height:100%;
  display:flex;
  align-items:center;
  justify-content:center;
}

.port-shape img{
  width:100%;
  height:100%;
  object-fit:cover; /* use contain if you don't want cropping */
  display:block;
}
.port-item:hover .port-shape{transform:scale(1.06) rotate(5deg)}
.port-overlay{position:absolute;inset:0;background:rgba(8,9,12,.85);display:flex;flex-direction:column;justify-content:flex-end;padding:2rem;opacity:0;transition:opacity .35s}
.port-cat{font-family:var(--font-mono);font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--orange);margin-bottom:.5rem}
.port-name{font-family:var(--font-main);font-size:1.1rem;font-weight:600;color:var(--white)}
.port-meta{font-family:var(--font-mono);font-size:.7rem;color:var(--muted);margin-top:.35rem}
.port-visual img{width:100%;height:100%;object-fit:cover;display:block;
}

/* ─── STATS ─── */
.stats-section{padding:5rem 2.5rem;background:var(--void);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:0}
.stat-item{padding:3rem 2.5rem;border-right:1px solid var(--line);position:relative}
.stat-item:last-child{border-right:none}
.stat-num-big{font-family:var(--font-mono);font-size:clamp(2.5rem,5vw,4.5rem);font-weight:500;color:var(--white);line-height:1;margin-bottom:.5rem}
.stat-num-big span{color:var(--orange)}
.stat-label-big{font-family:var(--font-mono);font-size:.7rem;letter-spacing:.15em;color:var(--muted);text-transform:uppercase}

/* ─── TEAM ─── */
.team-section{padding:7rem 2.5rem;background:var(--steel)}
.team-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:1px;background:var(--line);border:1px solid var(--line);margin-top:4rem}
.team-card{background:var(--void);padding:2rem 1rem;display:flex;flex-direction:column;align-items:center;gap:1rem;cursor:none;transition:background .3s;position:relative;overflow:hidden}
.team-card:hover{background:var(--plate)}
.team-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--orange);transform:scaleX(0);transition:transform .3s}
.team-card:hover::after{transform:scaleX(1)}
.team-avatar{width:64px;height:64px;border-radius:50%;object-fit:cover;border:2px solid var(--line);transition:border-color .3s;filter:grayscale(60%);transition:filter .3s,border-color .3s}
.team-card:hover .team-avatar{filter:grayscale(0);border-color:var(--orange)}
.team-name{font-family:var(--font-mono);font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);text-align:center;transition:color .3s}
.team-card:hover .team-name{color:var(--white)}

/* ─── PRINTER ANIMATION ─── */
.printer-section{padding:7rem 2.5rem;background:var(--void);display:flex;flex-direction:column;align-items:center}
.printer-wrap{position:relative;width:340px;height:380px;margin:3rem auto}
.printer-body{width:260px;height:200px;border:2px solid var(--muted);position:absolute;bottom:0;left:50%;transform:translateX(-50%);display:flex;flex-direction:column}
.printer-bed{width:220px;height:12px;background:var(--plate);border:1px solid var(--muted);position:absolute;bottom:40px;left:50%;transform:translateX(-50%)}
.printer-head{width:20px;height:20px;border:2px solid var(--orange);position:absolute;top:40px;left:50%;transform:translateX(-50%);animation:headSweep 3s ease-in-out infinite}
@keyframes headSweep{0%,100%{left:20%}50%{left:80%}}
.printer-filament{width:2px;height:0;background:var(--orange);position:absolute;top:60px;left:50%;transform:translateX(-50%);animation:filamentGrow 3s ease-in-out infinite;opacity:.7}
@keyframes filamentGrow{0%{height:0;opacity:0}20%{opacity:.7}100%{height:120px;opacity:.7}}
.layer-build{position:absolute;bottom:52px;left:50%;transform:translateX(-50%);width:180px;height:0;background:linear-gradient(0deg,var(--orange-dim),var(--orange));opacity:.3;animation:layerUp 3s ease-in-out infinite}
@keyframes layerUp{0%{height:0}100%{height:80px}}
.printer-rail{position:absolute;top:20px;left:0;right:0;height:2px;background:var(--muted)}
.printer-desc{font-family:var(--font-mono);font-size:.75rem;color:var(--muted);text-align:center;max-width:420px;line-height:1.8;margin-top:2rem}
.print-status{font-family:var(--font-mono);font-size:.7rem;letter-spacing:.15em;color:var(--cyan);margin-top:1rem;text-align:center}
.blink{animation:blink 1.2s step-end infinite}
@keyframes blink{50%{opacity:0}}

/* ─── CONTACT ─── */
.contact-section{padding:7rem 2.5rem;background:var(--steel)}
.contact-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:6rem;margin-top:4rem}
.contact-item{display:flex;align-items:flex-start;gap:1.25rem;margin-bottom:2rem}
.ci-dot{width:6px;height:6px;border-radius:50%;background:var(--orange);flex-shrink:0;margin-top:.55rem}
.ci-label{font-family:var(--font-mono);font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:.3rem}
.ci-val{font-family:var(--font-mono);font-size:.85rem;color:var(--white)}
.social-row-ox{display:flex;gap:1rem;margin-top:3rem}
.soc-btn{width:40px;height:40px;border:1px solid var(--line);display:flex;align-items:center;justify-content:center;color:var(--muted);text-decoration:none;font-family:var(--font-mono);font-size:.8rem;transition:all .2s;cursor:none}
.soc-btn:hover{border-color:var(--orange);color:var(--orange)}
.form-ox{display:flex;flex-direction:column;gap:1.25rem}
.field-ox{display:flex;flex-direction:column;gap:.5rem}
.field-ox label{font-family:var(--font-mono);font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted)}
.field-ox input,.field-ox select,.field-ox textarea{background:var(--void);border:1px solid var(--line);color:var(--white);font-family:var(--font-mono);font-size:.82rem;padding:.85rem 1rem;outline:none;transition:border-color .2s;-webkit-appearance:none;border-radius:0}
.field-ox input:focus,.field-ox select:focus,.field-ox textarea:focus{border-color:var(--orange)}
.field-ox textarea{resize:vertical;min-height:120px}
.field-ox select option{background:var(--void)}
.drop-zone{border:1px dashed var(--line);padding:2rem;display:flex;flex-direction:column;align-items:center;gap:.75rem;cursor:none;transition:border-color .2s}
.drop-zone:hover,.drop-zone.dz-over{border-color:var(--orange)}
.drop-zone p{font-family:var(--font-mono);font-size:.75rem;color:var(--muted);text-align:center}
.drop-zone .dz-icon{width:36px;height:36px;stroke:var(--muted)}
.submit-btn-ox{background:var(--orange);color:var(--void);font-family:var(--font-mono);font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;padding:1.1rem 2.5rem;border:none;cursor:none;transition:all .25s;clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,0 100%);align-self:flex-start}
.submit-btn-ox:hover{background:var(--white);color:var(--void)}
.form-success{background:rgba(0,212,255,.06);border:1px solid rgba(0,212,255,.2);color:var(--cyan);font-family:var(--font-mono);font-size:.78rem;padding:1rem 1.25rem;display:none}
/* ─── FOOTER ─── */
.footer-ox{background:var(--void);border-top:1px solid var(--line);padding:3rem 2.5rem 2rem}
.footer-top{display:flex;justify-content:space-between;align-items:flex-start;padding-bottom:3rem;border-bottom:1px solid var(--line)}
.footer-brand-wrap{display:flex;align-items:center;gap:.75rem}
.footer-brand-name{font-family:var(--font-main);font-weight:700;font-size:1.2rem;letter-spacing:.1em;color:var(--white)}
.footer-links-row{display:flex;gap:3rem}
.footer-col h6{font-family:var(--font-mono);font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:1.25rem}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:.65rem}
.footer-col a{font-family:var(--font-mono);font-size:.75rem;color:var(--muted);text-decoration:none;transition:color .2s}
.footer-col a:hover{color:var(--orange)}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;padding-top:1.5rem}
.footer-copy{font-family:var(--font-mono);font-size:.65rem;color:var(--muted)}
.footer-legal{display:flex;gap:2rem}
.footer-legal a{font-family:var(--font-mono);font-size:.65rem;color:var(--muted);text-decoration:none;transition:color .2s}
.footer-legal a:hover{color:var(--white)}

/* ─── UTILITIES ─── */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease}
.reveal.in{opacity:1;transform:translateY(0)}

@media(max-width:991px){
  .services-grid{grid-template-columns:repeat(2,1fr)}
  .mat-grid{grid-template-columns:repeat(3,1fr)}
  .team-grid{grid-template-columns:repeat(4,1fr)}
  .port-grid{grid-template-columns:repeat(2,1fr)}
  .port-item:first-child{grid-column:span 2;aspect-ratio:auto;aspect-ratio:2/1}
  .contact-grid{grid-template-columns:1fr;gap:3rem}
  .footer-top{flex-direction:column;gap:2.5rem}
  .footer-links-row{flex-wrap:wrap;gap:2rem}
  .steps{grid-template-columns:repeat(2,1fr)}
  .stats-row{grid-template-columns:1fr}
  .stat-item{border-right:none;border-bottom:1px solid var(--line);padding:2.5rem}
  .stat-item:last-child{border-bottom:none}
}
@media(max-width:767px){
  #nav{padding:1.25rem 1.25rem}
